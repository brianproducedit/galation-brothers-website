# Environment Variables for Galation Brothers Website
# Copy this file to .env and fill in your production values

# Formspree Endpoints (required for form submissions)
VITE_FORMSPREE_CONTACT_ENDPOINT=https://formspree.io/f/xyzcontact123
VITE_FORMSPREE_FEEDBACK_ENDPOINT=https://formspree.io/f/xyzfeedback456
VITE_FORMSPREE_NEWSLETTER_ENDPOINT=https://formspree.io/f/xyznewsletter789

# Contact Information
VITE_WHATSAPP_NUMBER=+263712345678
VITE_EMAIL_INFO=info@examplecompany.co.zw
VITE_EMAIL_CLAIMS=claims@examplecompany.co.zw

# Social Media Links
VITE_SOCIAL_FACEBOOK=https://facebook.com/examplecompany
VITE_SOCIAL_TWITTER=https://twitter.com/exampleco
VITE_SOCIAL_LINKEDIN=https://linkedin.com/company/example-company
VITE_SOCIAL_INSTAGRAM=https://instagram.com/examplecompany